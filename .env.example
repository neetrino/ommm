# Single monorepo `.env` at the repo root (copy to `.env`, never commit secrets).
# Loaded by: Next (`apps/web`), Nest (`apps/api`, see `envFilePath`), Expo (`apps/mobile/app.config.ts` loads this file + optional root `.env.local`).
# Optional overrides: `apps/web/.env.local`, `apps/api/.env` (Nest precedence).

# Application
NODE_ENV="development"
APP_URL="http://localhost:3000"
WEB_APP_URL="http://localhost:3000"
# Optional comma-separated extra browser origins for Nest CORS (e.g. Expo web on LAN: http://192.168.1.10:8081)
# CORS_ORIGINS=""
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:4000"
# Expo (client bundle — use EXPO_PUBLIC_* only for mobile; no secrets).
# In development, `apps/mobile` can auto-pick the API host when this is unset (see `src/lib/api/config.ts`).
# When set: Android emulator → `http://10.0.2.2:4000` (Nest must listen on 0.0.0.0 — default in `apps/api`).
# Physical phone: `http://<your-PC-LAN-IP>:4000`. iOS Simulator / Expo Web: `http://localhost:4000` (or leave unset in dev).
# If `10.0.2.2` times out on the emulator: allow TCP 4000 in Windows Firewall, or `adb reverse tcp:4000 tcp:4000` and use `http://127.0.0.1:4000`.
# Production mobile builds must set this explicitly.
EXPO_PUBLIC_API_URL="http://10.0.2.2:4000"
# Next rewrites: server-side proxy to Nest (`apps/web/next.config.ts`)
API_INTERNAL_URL="http://127.0.0.1:4000"
# Nest HTTP port (optional; default 4000 in code)
PORT="4000"
# Bind address for Nest (default 0.0.0.0 — needed for Android emulator / LAN). Example: 127.0.0.1 for localhost-only.
# API_LISTEN_HOST="0.0.0.0"

# Database Configuration
# Neon: pooled URL for the app; direct (non-pooler) for migrations / Prisma `directUrl`
DATABASE_URL=""
DIRECT_URL=""
DATABASE_CONNECTION_LIMIT="10"
DATABASE_POOL_TIMEOUT="20"


# Authentication
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
# JWT expiry in seconds (Nest). Optional legacy string in docs: JWT_EXPIRES_IN
JWT_EXPIRES_SEC="604800"

# Stripe (optional until payments go live)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_CURRENCY="usd"


# ——— Cache (Upstash Redis) ———
UPSTASH_REDIS_REST_URL="https://..."
UPSTASH_REDIS_REST_TOKEN=""


# ——— Email ———
# `log` / `test` = only log to Nest console (no Resend). Default when NODE_ENV is not production.
# `resend` = send via Resend (needs valid RESEND_API_KEY). Default when NODE_ENV=production.
# MAIL_TRANSPORT="log"
# MAIL_TRANSPORT="resend"

# ——— Resend (only when MAIL_TRANSPORT=resend) ———
RESEND_API_KEY=""
RESEND_FROM_EMAIL="test@neetrino.com"
RESEND_FROM="Ommm <onboarding@resend.dev>"

# ——— File storage (Cloudflare R2) — Home banner uploads use S3 API when these are set; otherwise the API falls back to local disk under `/v1/uploads/`.
# Account ID builds default endpoint `https://<id>.r2.cloudflarestorage.com` if R2_S3_ENDPOINT is empty.
R2_ACCOUNT_ID=""
# S3-compatible API URL (optional if R2_ACCOUNT_ID is set)
R2_S3_ENDPOINT=""
# R2_API_TOKEN is for Cloudflare REST API (Workers). Home image upload uses R2_ACCESS_KEY_ID / R2_SECRET_ACCESS_KEY only.
R2_API_TOKEN=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
# Public bucket URL (e.g. *.r2.dev or custom domain), no trailing slash
R2_PUBLIC_URL=""
# Set to true to forbid local-disk fallback for home images (upload fails until R2 env is valid).
# R2_HOME_IMAGE_REQUIRED="false"

# ——— Figma (MCP) ———
FIGMA_ACCESS_TOKEN=""
