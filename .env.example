# Monorepo root `.env` is loaded by `apps/web` (Next) and `apps/api` (Nest).
# Optional overrides: `apps/web/.env.local`, `apps/api/.env` (see Nest `envFilePath` precedence).

# Application
NODE_ENV="development"
APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:4000"
# Nest HTTP port (optional; default 4000 in code)
PORT="4000"

# Database Configuration
# Neon: pooled URL for the app; direct (non-pooler) for migrations / Prisma `directUrl`
DATABASE_URL=""
DIRECT_URL=""
DATABASE_CONNECTION_LIMIT="10"
DATABASE_POOL_TIMEOUT="20"


# Authentication
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"


# ——— Cache (Upstash Redis) ———
UPSTASH_REDIS_REST_URL="https://..."
UPSTASH_REDIS_REST_TOKEN=""


# ——— Email (Resend) ———
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="test@neetrino.com"

# ——— File storage (Cloudflare R2) ———
# Account ID = subdomain of *.r2.cloudflarestorage.com
R2_ACCOUNT_ID=""
# S3-compatible API URL (jurisdiction “Default” in dashboard)
R2_S3_ENDPOINT=""
# Cloudflare API token (cfat_…), not the same as S3 keys
R2_API_TOKEN=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
# Public bucket URL (e.g. *.r2.dev or custom domain)
R2_PUBLIC_URL=""

# ——— Figma (MCP) ———
FIGMA_ACCESS_TOKEN=""
