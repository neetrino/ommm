{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "api: dev (colored logs)",
      "type": "shell",
      "command": "pnpm run dev",
      "options": {
        "cwd": "${workspaceFolder}/apps/api",
        "env": {
          "NODE_ENV": "development",
          "FORCE_COLOR": "1"
        }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      }
    }
  ]
}
