{
  "name": "ommm",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "postinstall": "pnpm run db:generate",
    "dev": "pnpm --parallel --filter \"./apps/*\" run dev",
    "dev:web": "pnpm --filter web dev",
    "build": "pnpm run build:web",
    "build:web": "pnpm --filter web build",
    "dev:api": "pnpm --filter api dev",
    "dev:mobile": "pnpm --filter mobile dev",
    "build:database": "pnpm --filter @ommm/database run build",
    "build:api": "pnpm run build:database && pnpm --filter api build",
    "db:generate": "pnpm exec prisma generate --schema packages/database/prisma/schema.prisma",
    "setup": "pnpm install",
    "test": "pnpm --filter api test",
    "test:e2e:web": "pnpm --filter web test:e2e"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "prisma": "^6.19.3"
  }
}
